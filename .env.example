# GEMINI_API_KEY: Required for generating design variants, suggestions, and carrying out chat conversations.
# This is loaded at build time and injected via the Vite configuration setup.
GEMINI_API_KEY="AI_STUDIO_OR_GEMINI_KEY"

# OPENROUTER_API_KEY: Fallback model key when Gemini API is unconfigured or rate-limited.
OPENROUTER_API_KEY=""

# VITE_STRIPE_PUBLISHABLE_KEY: Your Stripe Publishable Key.
# Used on the client-side to authorize secure transaction tunnels with Stripe.
VITE_STRIPE_PUBLISHABLE_KEY="pk_test_stripe_publishable_key_here"

# STRIPE_SECRET_KEY: Secret backend subscription key from your Stripe Dashboard (Developers -> API Keys).
# MUST stay hidden on the server, never visible in browser inspect panels.
STRIPE_SECRET_KEY="sk_test_stripe_secret_key_here"

# STRIPE_WEBHOOK_SECRET: Secret for signing and validating Stripe webhooks securely (whsec_...).
STRIPE_WEBHOOK_SECRET="whsec_stripe_webhook_secret_here"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
APP_URL="MY_APP_URL"

# VITE_STRIPE_PAYMENT_LINK: Optional Stripe Payment Link (e.g., https://buy.stripe.com/abc...)
# Perfect fallback for custom static domains (like www.thedesignai.com) running without a Node backend!
VITE_STRIPE_PAYMENT_LINK=""
