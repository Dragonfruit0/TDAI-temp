rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net default-deny gate
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    // Check if the user is authenticated
    function isAuthenticated() {
       return request.auth != null;
    }
    
    // Check if the user is a systems administrator
    function isAdmin() {
       return isAuthenticated() && 
              request.auth.token.email == 'thedesignai3@gmail.com' && 
              request.auth.token.email_verified == true;
    }
    
    // Check if user owns the resource (for user-owned documents)
    function isOwner(userId) {
       return isAuthenticated() && request.auth.uid == userId;
    }

    // Prevent ID poisoning Attacks
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // ===============================================================
    // Domain Validators (Type checks & basic shape validations)
    // ===============================================================

    function isValidUser(data) {
      return data.uid is string && data.uid.size() > 0 &&
             data.email is string && data.email.size() > 0 &&
             data.createdAt is string;
    }

    function isValidProject(data) {
      return data.userId is string && data.userId.size() > 0 &&
             data.prompt is string && data.prompt.size() > 0 &&
             data.variants is list &&
             data.createdAt is string;
    }

    function isValidSavedDesign(data) {
       return data.userId is string && data.userId.size() > 0 &&
              data.name is string && data.name.size() > 0 &&
              data.html is string && data.html.size() > 0 &&
              data.createdAt is string;
    }

    function isValidChatbotUsage(data) {
       return data.userId is string && data.userId.size() > 0 &&
              data.userEmail is string && data.userEmail.size() > 0 &&
              data.prompt is string && data.prompt.size() > 0 &&
              data.createdAt is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow get: if (isOwner(userId) || isAdmin()) && isValidId(userId);
      allow list: if isAdmin();
      allow create: if isOwner(userId) && 
                       isValidUser(request.resource.data) &&
                       request.resource.data.uid == userId &&
                       isValidId(userId);
      allow update: if isValidId(userId) && (
                       (isOwner(userId) && 
                        isValidUser(request.resource.data) &&
                        request.resource.data.uid == userId) ||
                       isAdmin()
                    );
      allow delete: if isAdmin() && isValidId(userId);
    }

    match /projects/{projectId} {
      allow get: if (isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid)) && isValidId(projectId);
      allow list: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && 
                       isValidProject(request.resource.data) &&
                       request.resource.data.userId == request.auth.uid &&
                       isValidId(projectId);
      allow update: if isAdmin() && isValidId(projectId);
      allow delete: if (isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid)) && isValidId(projectId);
    }

    match /saved_designs/{savedDesignId} {
      allow get: if (isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid)) && isValidId(savedDesignId);
      allow list: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && 
                       isValidSavedDesign(request.resource.data) &&
                       request.resource.data.userId == request.auth.uid &&
                       isValidId(savedDesignId);
      allow update: if isAdmin() && isValidId(savedDesignId);
      allow delete: if (isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid)) && isValidId(savedDesignId);
    }

    match /chatbot_usage/{usageId} {
      allow get: if isAdmin() && isValidId(usageId);
      allow list: if isAdmin();
      allow create: if isAuthenticated() && 
                       isValidChatbotUsage(request.resource.data) &&
                       request.resource.data.userId == request.auth.uid &&
                       isValidId(usageId);
      allow update, delete: if isAdmin() && isValidId(usageId);
    }
  }
}
