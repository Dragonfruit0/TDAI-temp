rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────────────────────────────
    // Global default-deny. Every path below must explicitly grant access.
    // ─────────────────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }

    // ═════════════════════════════════════════════════════════════════
    // HELPERS
    // ═════════════════════════════════════════════════════════════════

    // Caller is signed-in.
    function isAuthed() {
      return request.auth != null;
    }

    // Caller is the designated admin account with a verified email.
    // email_verified ensures the Google session is fully authenticated.
    function isAdmin() {
      return isAuthed()
          && request.auth.token.email      == 'thedesignai3@gmail.com'
          && request.auth.token.email_verified == true;
    }

    // Caller owns the document identified by uid.
    function isOwner(uid) {
      return isAuthed() && request.auth.uid == uid;
    }

    // Auto-generated Firestore IDs are 20 alphanumeric chars.
    // Blocks path-segment injection with special characters.
    function safeId(id) {
      return id is string
          && id.size() > 0
          && id.size() <= 128
          && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // ─── Field-change helpers ─────────────────────────────────────────

    // Keys whose values differ between the incoming write and the stored doc.
    function changedKeys() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }

    // Owners must never touch 'subscription' (written only by Admin SDK via
    // Stripe webhook) or 'email' (comes from Google OAuth, not editable).
    function protectedFieldsUnchanged() {
      return !changedKeys().hasAny(['subscription', 'email']);
    }

    // ═════════════════════════════════════════════════════════════════
    // SCHEMA VALIDATORS
    // ═════════════════════════════════════════════════════════════════

    // ── users ─────────────────────────────────────────────────────────

    // Called on the very first sign-in when the document is created.
    // subscription MUST be absent — it is only ever written by the
    // server-side Stripe webhook through the Admin SDK.
    function validUserCreate(d) {
      return d.uid      is string && d.uid.size() > 0 && d.uid == request.auth.uid
          && d.email    is string && d.email.size() > 0 && d.email.size() <= 320
          && d.createdAt is string && d.createdAt.size() > 0
          && !('subscription' in d)
          && d.keys().hasOnly([
               'uid', 'email', 'displayName', 'photoURL', 'createdAt', 'lastLoginAt'
             ]);
    }

    // Called on every subsequent sign-in (setDoc with merge:true).
    // Only display-layer fields are allowed to change; subscription and email
    // are frozen for non-admin callers.
    function validUserUpdate(d) {
      return d.uid   is string && d.uid.size() > 0
          && d.email is string && d.email.size() > 0
          && protectedFieldsUnchanged()
          && changedKeys().hasOnly(['displayName', 'photoURL', 'lastLoginAt', 'createdAt']);
    }

    // ── projects ──────────────────────────────────────────────────────

    function validProject(d) {
      return d.userId  is string && d.userId == request.auth.uid
          && d.prompt  is string && d.prompt.size() > 0  && d.prompt.size() <= 5000
          && d.variants is list  && d.variants.size() <= 10
          && d.createdAt is string && d.createdAt.size() > 0;
    }

    // ── saved_designs ─────────────────────────────────────────────────

    function validSavedDesign(d) {
      return d.userId is string && d.userId == request.auth.uid
          && d.name   is string && d.name.size() > 0 && d.name.size() <= 200
          && d.html   is string && d.html.size() > 0
          && d.createdAt is string && d.createdAt.size() > 0;
    }

    // ── chatbot_usage ─────────────────────────────────────────────────

    function validChatbotUsage(d) {
      return d.userId    is string && d.userId == request.auth.uid
          && d.userEmail is string && d.userEmail.size() > 0 && d.userEmail.size() <= 320
          && d.prompt    is string && d.prompt.size() > 0    && d.prompt.size() <= 5000
          && d.createdAt is string && d.createdAt.size() > 0;
    }

    // ═════════════════════════════════════════════════════════════════
    // RULES — users
    // ═════════════════════════════════════════════════════════════════
    match /users/{userId} {

      // A user may read their own document; the admin may read any.
      allow get: if safeId(userId) && (isOwner(userId) || isAdmin());

      // Only the admin dashboard may list all users.
      allow list: if isAdmin();

      // Created once on first Google sign-in.
      allow create: if safeId(userId)
                    && isOwner(userId)
                    && validUserCreate(request.resource.data)
                    && request.resource.data.uid == userId;

      // Owners may only refresh display fields.
      // Admins (including the admin dashboard subscription toggle) are unrestricted.
      allow update: if safeId(userId) && (
                       (isOwner(userId) && validUserUpdate(request.resource.data))
                    || isAdmin()
                    );

      // Only admins may permanently remove user records.
      allow delete: if isAdmin();
    }

    // ═════════════════════════════════════════════════════════════════
    // RULES — projects
    // ═════════════════════════════════════════════════════════════════
    match /projects/{projectId} {

      // Single-document read: owner or admin.
      allow get: if safeId(projectId)
                 && (isAdmin() || (isAuthed() && resource.data.userId == request.auth.uid));

      // Collection query: Firestore validates that the client's where('userId','==',uid)
      // clause guarantees the condition below, so only a user's own projects are returned.
      allow list: if isAdmin()
                  || (isAuthed() && resource.data.userId == request.auth.uid);

      // Logged-in users create their own projects. userId is validated inside the
      // schema function, so no userId forgery is possible.
      allow create: if safeId(projectId)
                    && isAuthed()
                    && validProject(request.resource.data);

      // Generated designs are immutable to users — only admins may edit metadata.
      allow update: if isAdmin();

      // Users may delete their own projects; admins may delete any.
      allow delete: if safeId(projectId)
                    && (isAdmin() || (isAuthed() && resource.data.userId == request.auth.uid));
    }

    // ═════════════════════════════════════════════════════════════════
    // RULES — saved_designs
    // ═════════════════════════════════════════════════════════════════
    match /saved_designs/{savedDesignId} {

      allow get: if safeId(savedDesignId)
                 && (isAdmin() || (isAuthed() && resource.data.userId == request.auth.uid));

      allow list: if isAdmin()
                  || (isAuthed() && resource.data.userId == request.auth.uid);

      allow create: if safeId(savedDesignId)
                    && isAuthed()
                    && validSavedDesign(request.resource.data);

      // Saved designs are snapshots — users cannot edit them, only delete and re-save.
      allow update: if isAdmin();

      allow delete: if safeId(savedDesignId)
                    && (isAdmin() || (isAuthed() && resource.data.userId == request.auth.uid));
    }

    // ═════════════════════════════════════════════════════════════════
    // RULES — chatbot_usage
    // Users may only append their own usage records (write-once audit log).
    // All read / edit / delete access is restricted to the admin.
    // ═════════════════════════════════════════════════════════════════
    match /chatbot_usage/{usageId} {

      allow get:            if isAdmin();
      allow list:           if isAdmin();

      allow create:         if safeId(usageId)
                            && isAuthed()
                            && validChatbotUsage(request.resource.data);

      allow update, delete: if isAdmin();
    }
  }
}
